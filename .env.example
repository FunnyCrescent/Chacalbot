# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# OpenRouter API Key (or any OpenAI-compatible provider)
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model IDs (change to your preferred models)
MASTER_MODEL=z-ai/glm-5.2
MASTER_TEMP=0.7
MASTER_MAX_TOKENS=65536

DB_MODEL=deepseek/deepseek-v4-flash
DB_TEMP=0.1
DB_MAX_TOKENS=16384

RENDERER_MODEL=xiaomi/mimo-v2.5
RENDERER_TEMP=0.0
RENDERER_MAX_TOKENS=16384

MEMORY_MODEL=xiaomi/mimo-v2.5
MEMORY_TEMP=0.3
MEMORY_MAX_TOKENS=8192

# Game settings
SETTING=dark_fantasy
DND_EDITION=5e_2024
MAX_PLAYERS=6
MAX_HISTORY=50

# Optional: Admin channel for telemetry
ADMIN_CHAT_ID=
